# ── GitHub ─────────────────────────────────────────────────────────────────────
# One or more GitHub personal access tokens (classic), comma-separated.
# Minimum scopes: read:user, read:org
# Create at: https://github.com/settings/tokens
# Used for: GitHub GraphQL profile fetching + user search
# Rate limit: 5,000 req/hr per token — add more tokens to scale
GITHUB_TOKENS=ghp_token1,ghp_token2,ghp_token3

# ── AWS / Bedrock ───────────────────────────────────────────────────────────────
# Region where the Lambda + Bedrock are deployed
AWS_REGION=eu-west-1

# Bedrock model for the TalentScoutAgent orchestrator (Sonnet = best reasoning)
BEDROCK_MODEL=eu.anthropic.claude-sonnet-4-5-20250929-v1:0

# Bedrock model for lightweight tasks: NL→query translation, 2-sentence summaries
BEDROCK_HAIKU_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# AWS account ID (used in SAM template and IAM policies)
AWS_ACCOUNT_ID=335400931736

# Lambda function name (set by SAM deploy — leave blank locally)
# TALENT_SCOUT_FUNCTION_NAME=mirai-talent-scout-TalentScoutFunction-XXXXX

# ── Supabase ────────────────────────────────────────────────────────────────────
# Project ref extracted from JWT: odnptiirmmcrxelmdikb
# Direct URL (port 5432): for migrations and one-off scripts
SUPABASE_URL=https://api.mirai-now.io
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9kbnB0aWlybW1lcnhlbG1kaWtiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTQ0Njg3OTcsImV4cCI6MjA3MDA0NDc5N30.uKWQa2sfNX3gaaaCmfPKl-7ecZib4PIKx0F21PiJvBU
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im9kbnB0aWlybW1lcnhlbG1kaWtiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1NDQ2ODc5NywiZXhwIjoyMDcwMDQ0Nzk3fQ.WDzuGqP40PQiYe8Cn9YQeVHAliRCkJR4bWNiq13KiBE

# PgBouncer pooler URL — REQUIRED for Lambda (handles concurrent connections)
# Format: postgresql://postgres.[ref]:[DB_PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Get DB password from: Supabase Dashboard > Project Settings > Database > Connection string
SUPABASE_DB_URL=postgresql://postgres.odnptiirmmcrxelmdikb:[YOUR_DB_PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ── Apify (LinkedIn enrichment) ────────────────────────────────────────────────
# Used by enrich_linkedin tool to scrape LinkedIn profiles via Apify actor
# Get your token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ── MCP Service ─────────────────────────────────────────────────────────────────
# Secret used to verify MCP requests (set in API Gateway + Lambda env)
MCP_AUTH_SECRET=

# ── Streaming chat agent (AgentStreamFunction) ─────────────────────────────────
# Lambda Function URL emitted by SAM as AgentStreamUrl output after deploy.
# Set this in ui/index.html as the STREAM_URL constant.
# Example: https://<id>.lambda-url.eu-west-1.on.aws/
STREAM_URL=https://gd7743h2wwqsgsasuiqib6twiq0hohfo.lambda-url.eu-west-1.on.aws/

# ── Local dev ───────────────────────────────────────────────────────────────────
# Set to "true" to skip real API calls and use test fixtures instead
USE_FIXTURES=false
LOG_LEVEL=INFO
